# ─────────────────────────────────────────
#  ORBIT Backend — Environment Variables
#  Copy this to .env and fill in your values
#  NEVER commit .env to git
# ─────────────────────────────────────────

# Supabase (get from: supabase.com → your project → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App
PORT=4000
NODE_ENV=development

# CORS — set to your frontend URL in production
# e.g. https://orbit.yourdomain.com or your Vercel/Netlify URL
FRONTEND_URL=http://localhost:3000

# Optional: a secret to verify webhook calls from Supabase
WEBHOOK_SECRET=change-me-to-a-random-string
